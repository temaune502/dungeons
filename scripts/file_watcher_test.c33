import std::io;
import std::thread;
import std::core::mem;
import std::core::mem::allocators;
import file_watcher;

import raylib6::rl;

fn int fake_main(String[] args)
{	
    rl::init_window(100, 100, "File Watcher");
    rl::close_window();


    
    // Створюємо арену
    BackedArenaAllocator* arena = allocators::new_backed_allocator(131072, mem)!!;

    FileWatcher fw;
    
    // Шлях без слеша на кінці
    if (!file_watcher::fw_init(&fw, arena, "C:/fw_test"))
    {
        io::printn("ПОМИЛКА ініціалізації.");
        rl::close_window();
        return 1;
    }

    io::printn("Watcher запущено. Змінюй файли в C:/fw_test");

    FileEvent[32] events; 

    while (true)
    {
        // Передаємо масив events (він автоматично стає вказівником)
        uint count = file_watcher::fw_poll(&fw, &events, 32);

        for (uint i = 0; i < count; i++)
        {
            io::print("Подія: ");
            switch (events[i].type)
            {
                case EVENT_CREATED: io::print("CREATED ");
                case EVENT_DELETED: io::print("DELETED ");
                case EVENT_MODIFIED: io::print("MODIFIED ");
                default: io::print("UNKNOWN ");
            }
            io::printn((ZString)events[i].path[0..events[i].path_len]);
        }

        thread::sleep_ms(500);
    }

    file_watcher::fw_destroy(&fw);
    rl::close_window();
    
    return 0;
}